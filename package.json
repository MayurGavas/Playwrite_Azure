{
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0"
  },
  "scripts": {
    "build": "npx playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:sanity": "playwright test --grep @sanity",
    "test:regression": "playwright test --grep @regression",
    "test:smoke:qa": "cross-env ENV=qa playwright test --grep @smoke",
    "test:smoke:sanity": "cross-env ENV=uat playwright test --grep @smoke",
    "test:smoke:prod": "cross-env ENV=prod playwright test --grep @smoke",
    "test:sanity:qa": "cross-env ENV=qa playwright test --grep @sanity",
    "test:sanity:sanity": "cross-env ENV=uat playwright test --grep @sanity",
    "test:sanity:prod": "cross-env ENV=prod playwright test --grep @sanity",
    "test:regression:qa": "cross-env ENV=qa playwright test --grep @regression",
    "test:regression:sanity": "cross-env ENV=uat playwright test --grep @regression",
    "test:regression:prod": "cross-env ENV=prod playwright test --grep @regression"
  }
}
