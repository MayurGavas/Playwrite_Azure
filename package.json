{
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "scripts": { 
    "build" : "npx playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:sanity": "playwright test --grep @sanity",
    "test:regression": "playwright test --grep @regression",

    "test:smoke:qa": "ENV=qa playwright test --grep @smoke",
    "test:smoke:sanity": "ENV=uat playwright test --grep @smoke",
    "test:smoke:prod": "ENV=prod playwright test --grep @smoke",

    "test:sanity:qa": "ENV=qa playwright test --grep @sanity",
    "test:sanity:sanity": "ENV=uat playwright test --grep @sanity",
    "test:sanity:prod": "ENV=prod playwright test --grep @sanity",

    "test:regression:qa": "ENV=qa playwright test --grep @regression",
    "test:regression:sanity": "ENV=uat playwright test --grep @regression",
    "test:regression:prod": "ENV=prod playwright test --grep @regression"
  }
}
